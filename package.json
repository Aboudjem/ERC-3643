{
  "name": "erc-3643",
  "version": "0.2.0",
  "description": "ERC-3643 Raptor — educational, gas-optimized, AI-ready reference implementation of the T-REX permissioned token standard for onchain securities and Real World Asset (RWA) tokenization.",
  "keywords": [
    "ERC-3643",
    "ERC3643",
    "EIP-3643",
    "EIP3643",
    "T-REX",
    "T-Rex Standard",
    "Raptor",
    "Tokenization",
    "Real World Assets",
    "Real World Asset",
    "RWA",
    "Security Tokens",
    "Security Token",
    "Permissioned Token",
    "Regulated Token",
    "Compliance",
    "ONCHAINID",
    "KYC",
    "AML",
    "Web3",
    "Smart Contracts",
    "Blockchain",
    "Solidity",
    "Tokeny Solutions",
    "STO",
    "MiCA"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "artifacts/contracts/**/*.json",
    "contracts/**/*.sol",
    "index.js",
    "index.d.ts",
    "AGENTS.md",
    "CLAUDE.md",
    "SECURITY.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md",
    "!contracts/_testContracts",
    "!artifacts/contracts/_testContracts",
    "!artifacts/build-info",
    "!**/*.dbg.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "build": "hardhat compile",
    "clean": "hardhat clean",
    "size": "hardhat size-contracts",
    "lint:ts": "eslint \"**/*.ts\"",
    "lint:ts:fix": "eslint \"**/*.ts\" --fix",
    "lint:sol": "prettier \"**/*.{json,sol,md}\" --check && solhint \"contracts/**/*.sol\"",
    "lint:sol:fix": "prettier \"**/*.{json,sol,md}\" --write && solhint \"contracts/**/*.sol\" --fix",
    "lint": "npm run lint:ts && npm run lint:sol",
    "lint:fix": "npm run lint:ts:fix && npm run lint:sol:fix",
    "slither": "slither . --config-file slither.config.json",
    "prepare": "husky install || true",
    "docs": "hardhat dodoc",
    "deploy:local": "hardhat run --network localhost scripts/deploy.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aboudjem/ERC-3643.git"
  },
  "author": "Adam Boudjemaa <adam@aboudjem.com> (https://github.com/Aboudjem)",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Aboudjem/ERC-3643/issues"
  },
  "homepage": "https://github.com/Aboudjem/ERC-3643#readme",
  "dependencies": {
    "@onchain-id/solidity": "^2.0.0",
    "@openzeppelin/contracts": "^4.9.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.6",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.8",
    "@nomiclabs/hardhat-solhint": "^3.0.1",
    "@primitivefi/hardhat-dodoc": "^0.2.3",
    "@typechain/ethers-v5": "^10.2.1",
    "@typechain/hardhat": "^6.1.6",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@xyrusworx/hardhat-solidity-json": "^1.0.2",
    "chai": "^4.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.2",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.10",
    "husky": "^8.0.3",
    "prettier": "^2.8.8",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^3.6.2",
    "solhint-plugin-prettier": "^0.0.5",
    "solidity-coverage": "^0.8.11",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.4.2"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{json,sol,md}": [
      "prettier --write"
    ]
  }
}
