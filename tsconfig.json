{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true
  },
  "include": ["./scripts", "./test", "./typechain", "./hardhat.config.ts"],
  "exclude": [
    "node_modules",
    "artifacts",
    "cache",
    "coverage",
    "docgen",
    "dist"
  ]
}
